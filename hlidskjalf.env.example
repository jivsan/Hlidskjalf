# Hlidskjalf environment — copy to `hlidskjalf.env` and fill in.
#
#   cp hlidskjalf.env.example hlidskjalf.env
#
# ⚠️  hlidskjalf.env holds SECRETS. It is git-ignored via .dockerignore for the
#     build context, but make sure you never commit it. Keep it 0600.
#
# This file is read by docker-compose `env_file:` — write `KEY=value`, one per
# line. Docker Compose DOES interpolate `$` in values (e.g. `$FOO`), so any value
# containing a literal `$` must be SINGLE-QUOTED to keep it verbatim — this
# matters for the argon2 hash below, which is full of `$`. JSON values have no
# `$`, so write them literally, e.g.  HLIDSKJALF_BANDWIDTH_QUOTAS={"115":500}
#
# NOTE for the plain `docker run --env-file` path (docs/docker.md): that reader
# does NOT interpolate and does NOT strip quotes, so there you must REMOVE the
# single quotes around the hash. Compose is the recommended path.
#
# How to obtain the PVE token / TLS fingerprint and how to generate the argon2
# password hash: see docs/bootstrap.md (§1) and docs/docker.md.

# --- Panel login (single admin user) ---------------------------------------
# Signing key for the session cookie. Generate once:  openssl rand -hex 32
HLIDSKJALF_SESSION_SECRET=CHANGE_ME_openssl_rand_hex_32

# Admin username (default: christina).
HLIDSKJALF_ADMIN_USER=christina

# argon2id hash of the admin password (NOT the plaintext). Generate with:
#   docker run --rm hlidskjalf:latest python -c \
#     "from argon2 import PasswordHasher; print(PasswordHasher().hash('your-password'))"
# (see docs/docker.md for a no-history variant that prompts for the password)
# SINGLE-QUOTED on purpose — keep the quotes so Compose does not eat the `$`.
HLIDSKJALF_ADMIN_PASSWORD_HASH='$argon2id$v=19$m=65536,t=3,p=4$CHANGE_ME'

# --- Proxmox VE API ---------------------------------------------------------
HLIDSKJALF_PVE_HOST=10.0.20.10
HLIDSKJALF_PVE_PORT=8006
HLIDSKJALF_PVE_NODE=hella
HLIDSKJALF_PVE_TOKEN_ID=hlidskjalf@pve!panel
# The token secret printed ONCE by `pveum user token add` (docs/bootstrap.md §1).
HLIDSKJALF_PVE_TOKEN_SECRET=CHANGE_ME_pve_token_secret
# SHA-256 fingerprint of hella's self-signed API cert, colon-separated hex
# (docs/bootstrap.md §1). REQUIRED over https — the panel refuses to connect
# to an unverified cert.
HLIDSKJALF_PVE_FINGERPRINT=AA:BB:CC:DD:...

# --- Behaviour --------------------------------------------------------------
# SystemRescue ISO volid used by the rescue tab.
HLIDSKJALF_RESCUE_ISO=local:iso/systemrescue-12.01-amd64.iso

# Comma-separated VMIDs that can never be destroyed/reinstalled/stopped/reset
# server-side (include the panel host itself, HAOS, PBS, …).
HLIDSKJALF_PROTECTED_VMIDS=151

# Optional, display-only monthly quotas: JSON map of vmid (string) -> GB/month.
# HLIDSKJALF_BANDWIDTH_QUOTAS={"115":500}

# Optional: per-VLAN default gateways offered in the provisioning form (JSON).
# HLIDSKJALF_VLAN_GATEWAYS={"20":"10.0.20.1","30":"","50":"10.0.50.1"}

# Optional: SSH public keys prefilled in the provisioning form (one per line;
# for a single line just paste the key).
# HLIDSKJALF_DEFAULT_SSH_KEYS=ssh-ed25519 AAAA... christina

# Optional: storage used for full clones (default local-lvm).
# HLIDSKJALF_CLONE_STORAGE=local-lvm

# --- Do NOT set these ------------------------------------------------------
# HLIDSKJALF_HOST / HLIDSKJALF_PORT / HLIDSKJALF_STATIC_DIR / HLIDSKJALF_STATE_DIR
# are baked into the image (0.0.0.0:8787, /app/static, /var/lib/hlidskjalf).
# HLIDSKJALF_PVE_SCHEME defaults to https and should stay https in production.
