# Hlidskjalf environment — copy to `hlidskjalf.env` and fill in.
#
#   cp hlidskjalf.env.example hlidskjalf.env
#
# ⚠️  hlidskjalf.env holds SECRETS. It is git-ignored via .dockerignore for the
#     build context, but make sure you never commit it. Keep it 0600.
#
# This file is read by docker-compose `env_file:` — write `KEY=value`, one per
# line. Docker Compose DOES interpolate `$` in values (e.g. `$FOO`), so any value
# containing a literal `$` must be SINGLE-QUOTED to keep it verbatim — this
# matters for the argon2 hash below, which is full of `$`. JSON values have no
# `$`, so write them literally, e.g.  HLIDSKJALF_BANDWIDTH_QUOTAS={"115":500}
#
# NOTE for the plain `docker run --env-file` path (docs/docker.md): that reader
# does NOT interpolate and does NOT strip quotes, so there you must REMOVE the
# single quotes around the hash. Compose is the recommended path.
#
# How to obtain the PVE token / TLS fingerprint and how to generate the argon2
# password hash: see docs/bootstrap.md (§1) and docs/docker.md.

# --- Panel login (single admin user) ---------------------------------------
# Signing key for the session cookie. Generate once:  openssl rand -hex 32
HLIDSKJALF_SESSION_SECRET=CHANGE_ME_openssl_rand_hex_32

# Admin username (default: admin).
HLIDSKJALF_ADMIN_USER=admin

# argon2id hash of the admin password (NOT the plaintext). Generate with:
#   docker run --rm hlidskjalf:latest python -c \
#     "from argon2 import PasswordHasher; print(PasswordHasher().hash('your-password'))"
# (see docs/docker.md for a no-history variant that prompts for the password)
# SINGLE-QUOTED on purpose — keep the quotes so Compose does not eat the `$`.
HLIDSKJALF_ADMIN_PASSWORD_HASH='$argon2id$v=19$m=65536,t=3,p=4$CHANGE_ME'

# Set the `Secure` flag on the session cookie (cookie only sent over HTTPS).
# Default is true — keep it true for any internet-facing / TLS deploy. Set it to
# false ONLY if the panel is reached over plain http (e.g. local dev, or you
# terminate TLS on a different host and the last hop is http you fully trust).
# HLIDSKJALF_COOKIE_SECURE=true

# --- Proxmox VE API ---------------------------------------------------------
# REQUIRED — your Proxmox host (IP or DNS name).
HLIDSKJALF_PVE_HOST=192.168.1.10
HLIDSKJALF_PVE_PORT=8006
# The Proxmox node name (`pvesh get /nodes`). A stock single-node install is "pve".
HLIDSKJALF_PVE_NODE=pve
HLIDSKJALF_PVE_TOKEN_ID=hlidskjalf@pve!panel
# The token secret printed ONCE by `pveum user token add` (docs/bootstrap.md §1).
HLIDSKJALF_PVE_TOKEN_SECRET=CHANGE_ME_pve_token_secret
# SHA-256 fingerprint of pve's self-signed API cert, colon-separated hex
# (docs/bootstrap.md §1). REQUIRED over https — the panel refuses to connect
# to an unverified cert.
HLIDSKJALF_PVE_FINGERPRINT=AA:BB:CC:DD:...

# --- Behaviour --------------------------------------------------------------
# SystemRescue ISO volid used by the rescue tab.
HLIDSKJALF_RESCUE_ISO=local:iso/systemrescue-12.01-amd64.iso

# Comma-separated VMIDs that can never be destroyed/reinstalled/stopped/reset
# server-side (include the panel host itself, HAOS, PBS, …).
# Guests the panel refuses to stop/reinstall/destroy/rescue. Empty = nothing
# protected. Put the VMID of whatever hosts this panel here.
HLIDSKJALF_PROTECTED_VMIDS=

# --- Arista switch (e.g. 7050TX) --------------------------------------------
# Enable eAPI on switch (preferred):
#   management api http-commands
#     protocol https
#     no shutdown
# Optional — an Arista switch with eAPI enabled. Leave unset to hide the Switch page.
# HLIDSKJALF_SWITCH_HOST=192.168.1.2
# HLIDSKJALF_SWITCH_USERNAME=admin
# HLIDSKJALF_SWITCH_PASSWORD=...
# The eAPI carries these switch credentials, so its TLS is verified. Preferred:
# pin the switch's (self-signed) eAPI cert by SHA-256 fingerprint, colon-hex:
#   openssl s_client -connect 192.168.20.2:443 </dev/null 2>/dev/null \
#     | openssl x509 -fingerprint -sha256 -noout
# HLIDSKJALF_SWITCH_FINGERPRINT=AA:BB:CC:DD:...
# Without a fingerprint, verification is against system CAs (switch_verify=true,
# the default). Set switch_verify=false to knowingly disable verification (logs a
# warning; credentials go over an unverified link — avoid for anything exposed).
# HLIDSKJALF_SWITCH_VERIFY=true

# Optional, display-only monthly quotas: JSON map of vmid (string) -> GB/month.
# HLIDSKJALF_BANDWIDTH_QUOTAS={"115":500}

# Optional: per-VLAN default gateways offered in the provisioning form (JSON).
# VLANs offered in the provision form, mapped to their gateway. Empty = no VLAN tagging.
# HLIDSKJALF_VLAN_GATEWAYS={"20":"192.168.20.1","30":""}

# Optional: SSH public keys prefilled in the provisioning form (one per line;
# for a single line just paste the key).
# HLIDSKJALF_DEFAULT_SSH_KEYS=ssh-ed25519 AAAA... you@example.com

# Optional: storage used for full clones (default local-lvm).
# HLIDSKJALF_CLONE_STORAGE=local-lvm

# Optional: DNS resolver written into every provisioned VM's cloud-init config
# (space-separated IPs for more than one). Point tenant VMs at the one resolver a
# locked-down DMZ permits. Empty = leave cloud-init's nameserver untouched.
# HLIDSKJALF_DEFAULT_NAMESERVER=9.9.9.9

# --- Metrics datasource (optional) ------------------------------------------
# Where the VM/node graphs come from: "rrd" (PVE rrddata, the default) or
# "prometheus" (panel-host's Prometheus + prometheus-pve-exporter scraping pve
# with this same PVE token). Prometheus buys finer long-range graphs — rrddata's
# month RRA is 12h-granular, its year RRA 1w. Full setup: docs/prometheus.md.
# HLIDSKJALF_METRICS_SOURCE=prometheus

# Base URL of the Prometheus HTTP API, WITHOUT the /api/v1 suffix. REQUIRED when
# HLIDSKJALF_METRICS_SOURCE=prometheus (the panel refuses to start without it).
# HLIDSKJALF_PROMETHEUS_URL=http://192.168.20.17:9090

# Optional auth for a Prometheus behind an auth proxy — a bearer token …
# HLIDSKJALF_PROMETHEUS_TOKEN=...
# … or HTTP basic auth.
# HLIDSKJALF_PROMETHEUS_USERNAME=...
# HLIDSKJALF_PROMETHEUS_PASSWORD=...

# TLS, only for an https:// Prometheus URL (same policy as PVE / the switch):
# pin a self-signed cert by SHA-256 fingerprint (colon-hex), otherwise it is
# verified against system CAs (HLIDSKJALF_PROMETHEUS_VERIFY=true, the default;
# set false to knowingly disable verification — logs a warning).
# HLIDSKJALF_PROMETHEUS_FINGERPRINT=AA:BB:CC:DD:...
# HLIDSKJALF_PROMETHEUS_VERIFY=true

# Seconds per query_range call (default 15).
# HLIDSKJALF_PROMETHEUS_TIMEOUT=15

# prometheus-pve-exporter publishes NO node iowait/loadavg/netin/netout (PVE's
# /cluster/resources has none), so those node graph series are empty with the
# prometheus source. Optionally supply PromQL for them (typically from a
# node_exporter on pve); JSON map of node field -> PromQL, with $node and $step
# (step in seconds) substituted.
# HLIDSKJALF_PROMETHEUS_NODE_QUERIES={"loadavg":"node_load1{instance=\"pve:9100\"}"}

# --- Public exposure (tenants from anywhere, admin from nowhere) -----------
# Only set these if the panel is reachable from the internet (a tunnel / port
# forward). See docs/public-access.md.
#
# HLIDSKJALF_PUBLIC declares the panel exposed. It changes nothing on its own, but
# with it set the panel REFUSES TO START unless the two below are also set — so an
# open admin login, or a panel blind to who is calling, cannot be deployed by
# accident.
# HLIDSKJALF_PUBLIC=true
#
# Whose X-Forwarded-For / CF-Connecting-IP may be believed. Behind Traefik or
# cloudflared on the same host this is the loopback. Without it every request is
# attributed to the proxy (audit log + per-IP limiter collapse onto one address).
# HLIDSKJALF_TRUSTED_PROXIES=127.0.0.1/32
#
# Networks from which admin is permitted (comma-separated CIDRs). Empty = anywhere
# (a LAN-only panel). 100.64.0.0/10 is the Tailscale range — a good admin boundary.
# HLIDSKJALF_ADMIN_NETWORKS=100.64.0.0/10,192.168.1.0/24

# --- Do NOT set these ------------------------------------------------------
# HLIDSKJALF_HOST / HLIDSKJALF_PORT / HLIDSKJALF_STATIC_DIR / HLIDSKJALF_STATE_DIR
# are baked into the image (0.0.0.0:8787, /app/static, /var/lib/hlidskjalf).
# HLIDSKJALF_PVE_SCHEME defaults to https and should stay https in production.
