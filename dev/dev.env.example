# Local development config — points the panel at the mocks in dev/, not real hardware.
# Copy to dev/dev.env (gitignored), then:
#
#   cd dev    && ../.venv/bin/uvicorn mock_pve:app --port 18006 &
#   cd dev    && ../.venv/bin/uvicorn mock_switch:app --port 18080 \
#                  --ssl-certfile mock_switch.crt --ssl-keyfile mock_switch.key &
#   cd backend && set -a && source ../dev/dev.env && set +a \
#                  && ../.venv/bin/uvicorn hlidskjalf.main:app --port 8787
#   cd frontend && npm run dev      # :5173, proxies /api to :8787

# --- mock Proxmox (dev/mock_pve.py) ---
HLIDSKJALF_PVE_HOST=127.0.0.1
HLIDSKJALF_PVE_PORT=18006
# Must match the node name Proxmox reports — node-scoped endpoints (node metrics,
# tasks) 404 if it does not. The mock uses Proxmox's own default, "pve".
HLIDSKJALF_PVE_NODE=pve
HLIDSKJALF_PVE_SCHEME=http
HLIDSKJALF_PVE_FINGERPRINT=
HLIDSKJALF_PVE_TOKEN_SECRET=mock-secret

# --- panel ---
HLIDSKJALF_ADMIN_USER=admin
# argon2 hash of "devpass":
#   python -c "from argon2 import PasswordHasher; print(PasswordHasher().hash('devpass'))"
HLIDSKJALF_ADMIN_PASSWORD_HASH=
HLIDSKJALF_SESSION_SECRET=dev-only-not-a-real-secret-0123456789
# The dev stack is plain http; a Secure cookie would never be sent back.
HLIDSKJALF_COOKIE_SECURE=false
HLIDSKJALF_STATE_DIR=/tmp/hlidskjalf-state

# Site-specific settings now default to EMPTY (the panel ships neutral, wired to
# nobody's homelab), so dev has to state its own.
HLIDSKJALF_PROTECTED_VMIDS=151
HLIDSKJALF_VLAN_GATEWAYS={"20":"192.168.20.1","30":"","50":"192.168.50.1"}
HLIDSKJALF_RESCUE_ISO=local:iso/systemrescue-12.01-amd64.iso

# --- mock Arista switch (dev/mock_switch.py) — optional; unset hides the page ---
HLIDSKJALF_SWITCH_HOST=127.0.0.1
HLIDSKJALF_SWITCH_PORT=18080
HLIDSKJALF_SWITCH_USERNAME=admin
HLIDSKJALF_SWITCH_PASSWORD=admin
# The mock serves a self-signed cert, so pin it (eAPI TLS is verified since v0.3.4):
#   openssl x509 -in dev/mock_switch.crt -noout -fingerprint -sha256 \
#     | cut -d= -f2 | tr -d ':' | tr 'A-F' 'a-f'
HLIDSKJALF_SWITCH_FINGERPRINT=

# Serve the built SPA from the backend (npm run build first). Leave empty to use
# the vite dev server on :5173 instead.
HLIDSKJALF_STATIC_DIR=
